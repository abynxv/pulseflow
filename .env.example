# Copy this to .env and fill in your values
# Get your key at https://openrouter.ai/keys
OPENAI_API_KEY=sk-or-v1-...

# OpenRouter endpoint (do not change)
API_BASE_URL=https://openrouter.ai/api/v1

# Model to use — free models need the :free suffix
# Full list: https://openrouter.ai/models
OPENAI_MODEL=meta-llama/llama-3.3-70b-instruct:free

# PostgreSQL — port 5433 avoids conflict with any local postgres
DATABASE_URL=postgresql+asyncpg://parseflow:parseflow@localhost:5433/parseflow

# Optional tuning (defaults shown)
MAX_FILE_SIZE_MB=10
MAX_TEXT_LENGTH=50000
MAX_RETRIES=3
